# ---------------------------------------------------------------------------
# Variables de entorno para la tienda (pago Stripe + entrega automática)
# Copia este archivo a .env.local y rellena los valores. NO subas .env.local.
# En Vercel: añádelas en Project → Settings → Environment Variables.
# ---------------------------------------------------------------------------

# Stripe — empieza con las claves de TEST (sk_test_… / whsec_…)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend — email de entrega de la descarga
RESEND_API_KEY=
# Remitente. En pruebas: "Sadoc <onboarding@resend.dev>" (solo a tu propio correo).
# En producción: un dominio verificado en Resend, p.ej. "Sadoc <descargas@sadocmix.com>"
EMAIL_FROM="Sadoc <onboarding@resend.dev>"

# Vercel Blob — almacenamiento de los archivos de producto
BLOB_READ_WRITE_TOKEN=

# Firma de los enlaces de descarga: una cadena aleatoria larga y secreta.
# Genérala con:  openssl rand -base64 32
DOWNLOAD_SIGNING_SECRET=

# URL pública del sitio (para construir los enlaces del email)
NEXT_PUBLIC_SITE_URL="https://sadocmix.vercel.app"
